{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "check-healthz-degraded": "tsx ./src/scripts/checkHealthzDegraded.ts",
    "check-production-hostname-pattern": "tsx ./src/scripts/checkProductionHostnamePattern.ts",
    "check-rate-limit-opt-out-inventory-drift": "tsx ./src/scripts/checkRateLimitOptOutInventoryDrift.ts",
    "check-readyz-config": "tsx ./src/scripts/checkReadyzConfig.ts",
    "check-readyz-dependency-probe-wire-shape": "tsx ./src/scripts/checkReadyzDependencyProbeWireShape.ts",
    "backfill-stream-owners": "tsx ./src/scripts/backfill-stream-owners.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.1",
    "@clerk/express": "^2.1.9",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/node": "^10.50.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/payments": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "otplib": "^12.0.1",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.5"
  }
}
